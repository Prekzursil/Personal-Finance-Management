#!/usr/bin/env bash
set -euo pipefail

# Temporary CI compatibility patch for deprecated jcenter usage.
sed -i 's/jcenter()/mavenCentral()/g' build.gradle app/build.gradle 2>/dev/null || true

if [[ ! -f ./gradlew ]]; then
  gradle wrapper --gradle-version 7.6.4 --no-daemon
fi
chmod +x ./gradlew

# Prefer full target; fallback to unit-test only for legacy plugin compatibility.
if ! ./gradlew --no-daemon testDebugUnitTest lintDebug; then
  ./gradlew --no-daemon testDebugUnitTest
fi
